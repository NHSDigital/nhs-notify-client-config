{
  "author": "",
  "dependencies": {
    "@asyncapi/bundler": "^0.6.4",
    "zod": "^4.0.17"
  },
  "description": "Schemas for NHS Notify client configuration",
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.15.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "main": "src/index.ts",
  "name": "@nhsdigital/nhs-notify-events-client-config",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": "git@github.com:NHSDigital/nhs-notify-client-config.git",
  "scripts": {
    "build": "tsc",
    "gen:asyncapi": "mkdir -p ./dist/asyncapi && ts-node src/cli/bundle-asyncapi.ts",
    "gen:jsonschema": "ts-node src/cli/generate-json.ts",
    "lint": "npm run lint:node && npm run lint:schema",
    "lint:fix": "eslint . --fix",
    "lint:node": "eslint .",
    "lint:schema": "spectral lint schemas/client-config.yaml",
    "prebuild": "rm -rf dist && npm run gen:asyncapi",
    "pregen:asyncapi": "npm run gen:jsonschema",
    "pregen:jsonschema": "rm -rf ./schemas/json",
    "prelint:schema": "npm run gen:jsonschema",
    "test": "jest",
    "test:unit": "jest"
  },
  "version": "1.0.2"
}
